<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F0F0F"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="30dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎵 Calming Sounds"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="30dp"/>

        <Button
            android:id="@+id/btnRain"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:text="🌧️ Rain"
            android:textSize="18sp"
            android:textStyle="bold"
            android:backgroundTint="#3D5A80"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/btnOcean"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:text="🌊 Ocean Waves"
            android:textSize="18sp"
            android:textStyle="bold"
            android:backgroundTint="#3D5A80"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/btnWhiteNoise"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:text="🎶 White Noise"
            android:textSize="18sp"
            android:textStyle="bold"
            android:backgroundTint="#3D5A80"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/btnStop"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:text="⏹️ Stop Sound"
            android:textSize="18sp"
            android:textStyle="bold"
            android:backgroundTint="#E57373"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="30dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🧘 Breathing Exercise"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#81C784"
            android:layout_marginBottom="20dp"/>

        <Button
            android:id="@+id/btnBreathing"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:text="Start Breathing"
            android:textSize="18sp"
            android:textStyle="bold"
            android:backgroundTint="#81C784"
            android:textColor="#000000"/>

    </LinearLayout>

</ScrollView>